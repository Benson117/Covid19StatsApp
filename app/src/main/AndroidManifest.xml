<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:dist="http://schemas.android.com/apk/distribution"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.android.covid19stats">


    <supports-screens
        android:largeScreens="true"
        android:normalScreens="true"
        android:smallScreens="true"
        android:xlargeScreens="true" />

    <dist:module dist:instant="true" />

    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.INTERNET" /> //the application relies on internet to give out updates

    <application
        android:allowBackup="true"
        android:icon="@drawable/virus"
        android:label="@string/app_name"
        android:roundIcon="@drawable/virus"
        android:supportsRtl="true"
        android:theme="@style/AppThemeNoActionBar">
        <activity android:name=".Activity.AboutApp" />
        <activity android:name=".Activity.covid19Hist" />
        <activity android:name=".Activity.EditProfile" />
        <activity android:name=".Activity.MainActivity2" />
        <activity android:name=".Activity.Register" />
        <activity android:name=".Activity.Login">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter> // The login screen is the first page to show when the app opens
        </activity>
        <activity
            android:name=".Activity.WelcomeScreenActivity"
            android:label="@string/app_name"
            tools:ignore="MissingClass" />
        <activity
            android:name=".Activity.MainActivity"
            android:label="@string/app_name"
            tools:ignore="MissingClass" />
        <activity
            android:name=".Activity.DetailsStatisticActivity"
            android:label="@string/app_name" />
        <activity
            android:name=".Activity.ChangeLanguageActivity"
            android:label="@string/app_name" />

        <meta-data
            android:name="preloaded_fonts"
            android:resource="@array/preloaded_fonts" />
    </application>

</manifest>